# Porta do servidor local
PORT=5000

# String de conexão do MongoDB Atlas (Substitua os campos entre < >)
MONGO_URI=mongodb+srv://<usuario>:<senha>@cluster.mongodb.net/juninhos_db

# ID da Planilha do Google (presente na URL da planilha)
GOOGLE_SHEET_ID=seu_google_sheet_id_aqui

# E-mail de envio de notificações (gmail)
EMAIL_USER=email@gmail.com

# JSON da conta de serviço do Google Cloud (deve ser o conteúdo do arquivo .json)
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"seu_projeto","private_key":"sua_chave_privada"}

# Chave de API do Resend para envio de e-mails
RESEND_API_KEY=re_sua_chave_aqui

# E-mail de destino para notificações (dominio personalizado)
NOTIFY_EMAIL=email@seu-dominio.com

# ============================
# Autenticação (Portal)
# ============================
# Segredo para assinar JWT (use uma string longa e aleatória — ex: `openssl rand -hex 64`)
JWT_SECRET=troque_isso_por_uma_string_longa_e_aleatoria
JWT_EXPIRES_IN=1d

# URL pública usada nos e-mails de reset de senha (frontend)
# Em dev: http://localhost:5173/reset-password
# Em prod: https://juninhos.com/reset-password
RESET_PASSWORD_URL=http://localhost:5173/reset-password

# Convite do Discord exibido no portal após login
DISCORD_INVITE_URL=https://discord.gg/juninhos
