# URL base dos endpoints públicos (projects, classes, waitlist, instructor).
# Vazio → usa fallback hardcoded (Render prod).
# VITE_API_BASE_URL=http://localhost:5000/api

# URL base dos endpoints de auth (register, login, forgot/reset password, portal).
# Vazio → cai pro mesmo valor de VITE_API_BASE_URL.
VITE_AUTH_API_BASE_URL=http://localhost:5000/api

# Código do convite permanente do servidor Discord.
# Exemplo: pra link `https://discord.gg/juninhos`, o código é `juninhos`.
#
# Como gerar:
# 1. No Discord, clica num canal público com botão direito → Convidar pessoas
# 2. Edita o link de convite: Expira em "Nunca" + Máx. de usos "Sem limite"
# 3. Copia só o código (parte depois de discord.gg/)
#
# Sem isso o stat cai pro fallback "+300 membros ativos".
VITE_DISCORD_INVITE_CODE=
